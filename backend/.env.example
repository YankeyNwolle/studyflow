# =============================================================================
# Backend StudyFlow — variables d'environnement (MODÈLE)
# Copier ce fichier en ".env" puis remplacer les valeurs par les vraies.
#   cp .env.example .env
# Le fichier .env est ignoré par Git (voir .gitignore) : ne jamais le committer.
# =============================================================================

# --- Serveur -----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- Base de données PostgreSQL ----------------------------------------------
# Option A : variables séparées
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studyflow
DB_USER=postgres
DB_PASSWORD=change_me

# Option B : URL de connexion unique (si tu préfères)
# DATABASE_URL=postgresql://postgres:change_me@localhost:5432/studyflow

# --- Authentification (JWT) --------------------------------------------------
# Générer une chaîne aléatoire longue, ex : openssl rand -hex 32
JWT_SECRET=remplace_par_une_longue_chaine_aleatoire
JWT_EXPIRES_IN=7d

# --- Sécurité / CORS ---------------------------------------------------------
# Origine autorisée à appeler l'API (l'URL du frontend)
CORS_ORIGIN=http://localhost:5173

# --- Uploads (documents — feature C) -----------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
