# =============================================================================
# .gitignore backend — Node.js / Express
# =============================================================================

# Dépendances
node_modules/

# Variables d'environnement (DB_URL, JWT_SECRET...)
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Tests / couverture
coverage/
.nyc_output/

# Fichiers uploadés par les utilisateurs (on garde le dossier, pas son contenu)
uploads/*
!uploads/.gitkeep

# Cache
.cache/
.eslintcache

# Dumps de base de données
*.sql.bak
*.dump
