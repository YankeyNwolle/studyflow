# =============================================================================
# Frontend StudyFlow — variables d'environnement (MODÈLE)
# Copier ce fichier en ".env" puis adapter les valeurs.
#   cp .env.example .env
#
# IMPORTANT (Vite) : seules les variables préfixées par VITE_ sont exposées
# au code React (import.meta.env.VITE_...). Ne jamais y mettre de secret :
# tout ce qui est ici est visible dans le navigateur.
# =============================================================================

# URL de base de l'API backend
VITE_API_URL=http://localhost:5000/api

# Nom de l'application (affiché dans l'UI)
VITE_APP_NAME=StudyFlow
